# ────────────────────────────────────────────────────────────
# Algero Platform — Root Environment Configuration
# Copy this file to .env and adjust values for your environment
# ────────────────────────────────────────────────────────────

# ─── Application ───────────────────────────────────────────
APP_NAME=Algero
APP_ENV=local
APP_DEBUG=true

# ─── Ports ────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ─── URLs (how the services see each other) ───────────────
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:8000

# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_DB=algero
POSTGRES_USER=algero
POSTGRES_PASSWORD=algero_secret
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432

# ─── Laravel ──────────────────────────────────────────────
APP_KEY=base64:CHANGE_ME_GENERATE_A_NEW_KEY
BCRYPT_ROUNDS=12
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

# ─── Sanctum / CORS ──────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:8000

# ─── Admin Credentials (seeder) ──────────────────────────
ADMIN_EMAIL=admin@algero.com
ADMIN_PASSWORD=password

# ─── Mail (default = log) ────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=hello@algero.com
MAIL_FROM_NAME=${APP_NAME}
